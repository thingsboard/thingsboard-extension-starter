# On-Premise Deployment Configuration
#
# Copy this file to .env and set values for your environment.
# See the project README for details.

# Docker image name (must match what build-image.sh produced)
IMAGE_NAME=thingsboard-extension

# Port the extension listens on (host:container)
SERVER_PORT=8090

# ThingsBoard URL — typically the host machine running ThingsBoard
# Use host.docker.internal to reach services on the Docker host
THINGSBOARD_URL=http://host.docker.internal:8080

# ThingsBoard credentials for scheduled tasks and background jobs.
# Set EITHER api-key OR username+password.
# Leave blank if only using request-based auth (X-Authorization header).
TB_AUTH_API_KEY=
TB_AUTH_USERNAME=
TB_AUTH_PASSWORD=

# CORS allowed origins — leave blank for on-premise (same-origin requests don't need CORS).
# Set only if widgets call the extension from a different origin.
CORS_ALLOWED_ORIGINS=

# JVM options (optional)
JAVA_OPTS=
