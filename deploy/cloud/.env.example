# Cloud Deployment Configuration
#
# Copy this file to .env and set values for your environment.
# See the project README for details.

# Docker image name (must match what build-image.sh produced)
IMAGE_NAME=thingsboard-extension

# Port the extension listens on (host:container)
SERVER_PORT=8090

# ThingsBoard Cloud URL — your tenant's URL
THINGSBOARD_URL=https://thingsboard.cloud

# ThingsBoard credentials for scheduled tasks and background jobs.
# Set EITHER api-key OR username+password.
# Leave blank if only using request-based auth (X-Authorization header).
TB_AUTH_API_KEY=
TB_AUTH_USERNAME=
TB_AUTH_PASSWORD=

# CORS allowed origins — REQUIRED for cloud deployments.
# Browser widget calls come from your ThingsBoard Cloud domain.
# Comma-separated for multiple origins.
# Example: https://thingsboard.cloud
# Example: https://thingsboard.cloud,https://custom.tb.cloud
CORS_ALLOWED_ORIGINS=https://thingsboard.cloud

# JVM options (optional)
JAVA_OPTS=
