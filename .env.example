# ThingsBoard Extension — Environment Variables
# Copy this file to .env and adjust as needed.

# Port the extension service listens on
SERVER_PORT=8090

# ThingsBoard base URL (default works when TB runs on the host machine)
THINGSBOARD_URL=http://host.docker.internal:8080

# Optional ThingsBoard credentials for the shared ThingsboardClient bean (scheduled tasks, etc.).
# Set EITHER API key OR username+password. API key takes precedence.
# TB_AUTH_API_KEY=YOUR_API_KEY
# TB_AUTH_USERNAME=tenant@thingsboard.org
# TB_AUTH_PASSWORD=tenant

# JVM options (e.g. memory limits)
JAVA_OPTS=
